{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/stripe-checkout",     "destination": "/api/stripe" },
    { "source": "/api/stripe-webhook",      "destination": "/api/stripe?route=webhook" },
    { "source": "/aide", "destination": "/aide/index.html" },
    { "source": "/((?!api/|aide|.+\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "functions": {
    "api/claude.js":              { "maxDuration": 60 },
    "api/facturx.js":             { "maxDuration": 60 },
    "api/account.js":             { "maxDuration": 60 },
    "api/admin-stats.js":         { "maxDuration": 60 },
    "api/admin-user-detail.js":   { "maxDuration": 60 },
    "api/admin-delete-user.js":   { "maxDuration": 60 },
    "api/stripe.js":              { "maxDuration": 30 },
    "api/devis-public.js":        { "maxDuration": 30 },
    "api/contact.js":             { "maxDuration": 15 },
    "api/newsletter.js":          { "maxDuration": 15 }
  }
}

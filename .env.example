# =========================================================
# Zenbat — Variables d'environnement (exemple)
# Copiez ce fichier en « .env.local » pour le dev local
# Ne JAMAIS commiter le vrai .env
# =========================================================

# Clé API Anthropic (obligatoire) — utilisée côté serveur par /api/claude.js
# À obtenir sur https://console.anthropic.com/
# ⚠️ Jamais exposée au navigateur : pas de préfixe VITE_
ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Modèle Claude par défaut (optionnel)
# CLAUDE_MODEL=claude-sonnet-4-5

# Origines autorisées en production (CSV, sans espace)
# Utilisé par api/claude.js pour durcir le CORS
# En preview/dev, laisser vide : l'origin de la requête sera renvoyé.
# ALLOWED_ORIGINS=https://zenbat.fr,https://www.zenbat.fr

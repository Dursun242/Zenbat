{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/aide", "destination": "/aide/index.html" },
    { "source": "/((?!api/|aide).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    },
    "api/facturx.js": {
      "maxDuration": 30,
      "includeFiles": "public/fonts/DejaVu*.ttf"
    }
  }
}
